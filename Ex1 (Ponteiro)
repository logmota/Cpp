/******************************************************************************

1-) Desenvolva um programa onde você crie 3 variáveis a, b e soma e dois ponteiros:
pont1 e pont2, todos do tipo int.
Peça para o usuário entrar com o valor de a e b via teclado e faça com que os 
ponteiros recebam o endereço de memória de a e b.

Exibir na tela o endereço de memória das variáveis a, b e dos dois ponteiros.
Some a e b e guarde dentro da variável soma.
Atribuir o conteúdo de soma para o ponteiro pont1 e exibir o conteúdo do pont1.

*******************************************************************************/

#include <iostream>
using namespace std;

int main()
{ 
    int a = 19;
    int b = 30;
    int soma;
    
    int *pont1 = &a;
    int *pont2 = &b;
    
    soma = *pont1 + *pont2;
    
    cout << "Valor da soma: " << soma << "\n";
    cout << "Endereço de memória do a: " << &a << "\n";
    cout << "Endereço de memória do b: " << &b << "\n";
    
    *pont1 = soma;
    cout << "Conteudo de pont1: " << *pont1;
    

    return 0;
}
